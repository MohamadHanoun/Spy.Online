rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function authed() { return request.auth != null; }

    match /rooms/{roomId} {
      function roomDoc() {
        return get(/databases/$(database)/documents/rooms/$(roomId));
      }
      function isHost() {
        return authed() && roomDoc().data.hostUid == request.auth.uid;
      }
      function isMember() {
        return authed() && exists(/databases/$(database)/documents/rooms/$(roomId)/publicPlayers/$(request.auth.uid));
      }
      function votesOpen() {
        return roomDoc().data.status == "playing" && roomDoc().data.voteStopped != true;
      }

      allow read: if authed();

      allow create: if authed()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == "lobby";

      allow update, delete: if isHost();

      match /publicPlayers/{playerId} {
        allow read: if isMember() || isHost();

        allow create, update: if authed()
          && playerId == request.auth.uid
          && roomDoc().data.status == "lobby";

        allow delete: if authed() && (playerId == request.auth.uid || isHost());
      }

      match /players/{playerId} {
        allow read: if authed() && playerId == request.auth.uid;

        allow create, update: if authed()
          && playerId == request.auth.uid
          && roomDoc().data.status == "lobby"
          && request.resource.data.role == "pending"
          && request.resource.data.word == ""
          && request.resource.data.categoryLabel == "";

        allow update: if isHost();

        allow delete: if authed() && (playerId == request.auth.uid || isHost());
      }

      match /private/{docId} {
        allow read, write: if isHost();
      }

      match /results/{docId} {
        allow read: if isHost() || (isMember() && roomDoc().data.status == "ended");
        allow create, update, delete: if isHost();
      }

      match /votes/{voteId} {
        allow read: if isMember() || isHost();

        allow create, update: if authed()
          && voteId == request.auth.uid
          && votesOpen();

        allow delete: if authed() && (voteId == request.auth.uid || isHost());
      }
    }
  }
}
